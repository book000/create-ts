{
  "name": "@book000/template",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "author": "book000",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "start": "tsx ./src/main.ts",
    "dev": "tsx watch ./src/main.ts",
    "test": "jest --runInBand --passWithNoTests --detectOpenHandles --forceExit",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "lint:prettier": "prettier --check src/",
    "lint:eslint": "eslint src/ -c eslint.config.mjs",
    "lint:tsc": "tsc --noEmit",
    "fix": "run-z fix:prettier fix:eslint",
    "fix:eslint": "eslint src/ -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src/",
    "generate-schema": "typescript-json-schema --required src/config.ts ConfigInterface -o schema/Configuration.json"
  },
  "dependencies": {
    "@book000/node-utils": "1.24.236",
    "discord.js": "14.26.4"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.15.4",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.3",
    "eslint": "10.5.0",
    "jest": "30.4.2",
    "prettier": "3.8.4",
    "run-z": "2.1.0",
    "ts-jest": "29.4.11",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-json-schema": "0.67.4"
  },
  "engines": {
    "node": "26.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/book000/template.git"
  },
  "bugs": {
    "url": "https://github.com/book000/template/issues"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  }
}
