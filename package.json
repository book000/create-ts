{
  "name": "@book000/create-ts",
  "version": "0.0.0",
  "description": "Create book000-style TypeScript projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/book000/create-ts"
  },
  "license": "MIT",
  "author": "book000",
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "bin": {
    "create-ts": "dist/index.mjs"
  },
  "main": "dist/index.mjs",
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": "26.5.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "lint:prettier": "prettier --check src",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint:tsc": "tsc",
    "fix": "run-z fix:prettier fix:eslint",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "1.7.0",
    "commander": "15.0.0",
    "execa": "10.0.0"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.16.15",
    "@types/node": "25.9.5",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "run-z": "2.1.0",
    "tsdown": "0.22.12",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
